{
  "wechat_webhook_url": "",
  "dingtalk_webhook_url": "",
  "feishu_webhook_url": "",
  "bark_url": "",
  "bark_icon": "",
  "pushplus_params": "",
  "magic_push_params": "",
  "smtp_params": "",
  "monitor_events": [
    "LoginSucc",
    "LoginFail",
    "Logout",
    "SSH_INVALID_USER",
    "SSH_AUTH_FAILED",
    "SSH_LOGIN_SUCCESS",
    "SSH_DISCONNECTED",
    "FoundDisk",
    "InsertDisk",
    "EjectDisk",
    "StorageBroken",
    "STORAGE_DEGRADED",
    "DiskWakeup",
    "DiskSpindown",
    "DISK_IO_ERR",
    "CPU_USAGE_ALARM",
    "CPU_USAGE_RESTORED",
    "CPU_TEMPERATURE_ALARM",
    "MEMORY_USAGE_ALARM",
    "MEMORY_USAGE_RESTORED",
    "SYSTEMD_SERVICE_STARTED",
    "SYSTEMD_SERVICE_STOPPED",
    "SYSTEMD_SERVICE_FAILED"
  ],
  "log_level": "INFO",
  "log_dir": "./data/logs",
  "http_pool_size": 10,
  "http_retry_count": 3,
  "http_timeout": 10,
  "dedup_window": 300,
  "cursor_dir": "./data/cursor",
  "logger_poll_interval": 2,
  "poll_batch_summary_enabled": false,
  "log_retention_days": 7,
  "title_prefix": "Linux",
  "minimal_push_enabled": false,
  "dnd_enabled": false,
  "dnd_start_time": "22:00",
  "dnd_end_time": "07:00",
  "web_password_enabled": true,
  "data_source": "journald",
  "syslog_paths": [
    "/var/log/auth.log",
    "/var/log/syslog",
    "/var/log/kern.log"
  ],
  "custom_patterns": [
    {
      "name": "SSH Login Attempts",
      "pattern": "sshd\\[\\d+\\]: (Accepted|Failed|Invalid) .* for (\\S+) from (\\S+) port",
      "event": "SSH_CUSTOM_EVENT",
      "groups": {
        "status": "$1",
        "user": "$2",
        "ip": "$3"
      }
    }
  ],
  "systemd_service_monitor": true,
  "systemd_service_exclude": [
    "dbus*.service",
    "systemd-*.service",
    "user@*.service"
  ],
  "resource_monitor_enabled": true,
  "cpu_alarm_threshold": 90,
  "memory_alarm_threshold": 90,
  "cpu_temp_alarm_threshold": 80,
  "resource_monitor_interval": 60,
  "system_patrol_enabled": false,
  "system_patrol_interval_minutes": 720,
  "notification_restart_enabled": true,
  "notification_restart_consecutive_failures": 10,
  "notification_restart_window": 1800,
  "notification_restart_cooldown": 3600
}